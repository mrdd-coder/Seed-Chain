# SeedChain Environment Configuration Template
# Copy this file to .env.local in the frontend directory

# Target Syndicate Registry Contract Address (deployed on Stellar Testnet or Local)
NEXT_PUBLIC_REGISTRY_ADDRESS=CDRegistryAddressExample1234567890Testnet

# Stellar Soroban RPC Network URL
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# Stellar Network Type: "TESTNET" or "LOCAL"
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
